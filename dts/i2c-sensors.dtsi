/*
 * Device Tree Include — I2C Environmental Sensors
 * Target: ARMv8-A QEMU virt board (PL011 + VirtIO)
 *
 * This fragment defines two I2C sensor nodes on bus i2c@1:
 *   - Bosch BMP280: Temperature + Barometric Pressure
 *   - InvenSense MPU6050: 6-axis Accelerometer + Gyroscope
 *
 * On real hardware this file would be included by the board-level
 * .dts via:   #include "i2c-sensors.dtsi"
 *
 * QEMU virt does not expose a real I2C controller, so this file
 * serves as a reference design for physical board bring-up.
 */

&i2c1 {
    status = "okay";
    clock-frequency = <400000>;  /* I2C Fast Mode — 400 kHz */

    /*
     * Bosch BMP280 — Digital Pressure & Temperature Sensor
     * Datasheet I2C address: 0x76 (SDO=GND) or 0x77 (SDO=VDD)
     * Linux driver: drivers/iio/pressure/bmp280-i2c.c
     */
    bmp280: pressure@76 {
        compatible = "bosch,bmp280";
        reg = <0x76>;
        status = "okay";

        /*
         * vdda-supply: Analog supply (1.71V - 3.6V)
         * vddd-supply: Digital supply (1.2V - 3.6V)
         * On dev boards these typically come from a fixed regulator.
         */
        /* vdda-supply = <&reg_3v3>; */
        /* vddd-supply = <&reg_1v8>; */
    };

    /*
     * InvenSense MPU6050 — 6-axis IMU (Accel + Gyro)
     * Datasheet I2C address: 0x68 (AD0=GND) or 0x69 (AD0=VDD)
     * Linux driver: drivers/iio/imu/inv_mpu6050/inv_mpu_i2c.c
     */
    mpu6050: imu@68 {
        compatible = "invensense,mpu6050";
        reg = <0x68>;
        status = "okay";

        /*
         * interrupt-parent = <&gpio1>;
         * interrupts = <7 IRQ_TYPE_EDGE_RISING>;
         *
         * mount-matrix:
         * Defines the physical orientation of the sensor on the PCB.
         * The kernel IIO subsystem uses this matrix to transform
         * raw axis data into the device's real coordinate system.
         */
        /* mount-matrix = "1",  "0",  "0",
                          "0",  "1",  "0",
                          "0",  "0",  "1"; */
    };
};
